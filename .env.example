# Bridge Bank configuration
# Copy this file to .env and fill in your values

# Bridge Bank licence key (received after purchase)
LICENCE_KEY=

# Enable Banking (from enablebanking.com)
# Your Application ID — matches the filename of your .pem key file
EB_APPLICATION_ID=

# Actual Budget
ACTUAL_URL=http://your-actual-budget-address:5006
ACTUAL_PASSWORD=
ACTUAL_SYNC_ID=
ACTUAL_ACCOUNT=

# Email notifications
NOTIFY_EMAIL=
SMTP_USER=
SMTP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587

# Sync settings
SYNC_TIME=06:00
ACCOUNT_HOLDER_NAME=

